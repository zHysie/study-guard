{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "学习守门员",
  "version": "0.1.1",
  "identifier": "com.local.study-guardian",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "学习守门员",
        "url": "index.html",
        "width": 1006,
        "height": 760,
        "minWidth": 900,
        "minHeight": 680,
        "decorations": false,
        "resizable": true
      },
      {
        "label": "banner",
        "title": "学习守门员提醒",
        "url": "index.html?window=banner",
        "width": 1280,
        "height": 92,
        "x": 0,
        "y": 0,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "visible": false,
        "focusable": false
      },
      {
        "label": "overlay",
        "title": "",
        "url": "index.html?window=overlay",
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "visible": false,
        "focusable": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
